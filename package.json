{
  "name": "12-0",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Build the perfect NBA player, simulate their career, try to go 12-0 in the Finals.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "data:build": "tsx scripts/data/build.ts",
    "data:validate": "tsx scripts/data/validate.ts",
    "data:audit": "tsx scripts/data/audit.ts",
    "data": "npm run data:build && npm run data:validate"
  },
  "dependencies": {
    "framer-motion": "^11.11.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "csv-parse": "^6.2.1",
    "eslint": "^9.17.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.8"
  }
}
